        <!-- ===== 四大坑便签 ===== -->
        <mxCell id="p1" value="坑① 成本爆炸 → 风险点：共享历史&#10;共享完整历史是 O(轮数²) token；&#10;对策：通信 = 上下文工程，worker&#10;过程不出门，只回传结论摘要" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
