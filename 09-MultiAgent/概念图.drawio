        <mxCell id="reviewer" value="reviewer 评审员" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#aed6f1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="1340" y="500" width="200" height="60" as="geometry" />
        </mxCell>
