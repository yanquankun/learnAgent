        <mxCell id="p2" value="坑② 无限互踢 → 风险点：路由环&#10;A↔B 死循环，由护栏强制终止" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
