        </mxCell>
        <mxCell id="p4" value="坑④ 责任不清 → 风险点：职责划分&#10;prompt 显式写明各 worker 边界" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="610" y="420" width="200" height="70" as="geometry" />
