<mxfile host="app.diagrams.net" type="device">
  <diagram id="concept-map" name="概念图">
    <mxGraphModel dx="1400" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== 泳道背景 ===== -->
        <mxCell id="zoneS" value="选型前置判断：要不要上 MultiAgent？" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=none;strokeColor=#999999;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="420" height="720" as="geometry" />
        </mxCell>
        <mxCell id="zoneM" value="Supervisor 协作架构（主数据流 + 评审回路）" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=none;strokeColor=#999999;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="1160" height="720" as="geometry" />
        </mxCell>
        <mxCell id="zoneE" value="对照实验区：单 vs 多 Agent 三维对比" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=none;strokeColor=#999999;strokeWidth=2;dashed=1;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;fontSize=15;fontStyle=1;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="40" y="790" width="1620" height="370" as="geometry" />
        </mxCell>

        <!-- ===== 左侧：选型前置判断 ===== -->
        <mxCell id="start" value="新需求：要上 MultiAgent 吗？" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#76e3c8;strokeColor=#333333;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="110" y="90" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="tri" value="三标准：可并行？&#10;需隔离？&#10;专业化收益 &gt; 成本？" style="shape=rhombus;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#f9e79f;strokeColor=#333333;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="110" y="180" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="exit_single" value="出口：单 Agent +&#10;好工具就够（多数场景）" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#a9dfbf;strokeColor=#333333;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="70" y="360" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="modes" value="四模式选择" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#f9e79f;strokeColor=#333333;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="270" y="360" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s_modes" value="四种协作模式：&#10;① Supervisor 中央调度（本课主干）&#10;② Hierarchical 层级&#10;③ Network 网络互连&#10;④ Pipeline 流水线" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
          <mxGeometry x="110" y="470" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s_first" value="先判断「要不要」，再学「怎么做」，&#10;最后用对照实验验证「值不值」" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
