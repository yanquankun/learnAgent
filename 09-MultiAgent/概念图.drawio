          <mxGeometry x="1350" y="640" width="170" height="85" as="geometry" />
        </mxCell>
        <mxCell id="final" value="最终产出（终稿）" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#a9dfbf;strokeColor=#333333;strokeWidth=2;fontSize=14;fontStyle=1;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="740" y="560" width="200" height="60" as="geometry" />
