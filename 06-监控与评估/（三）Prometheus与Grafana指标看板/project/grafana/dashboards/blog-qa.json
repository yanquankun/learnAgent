{
  "title": "博客问答服务监控",
  "uid": "blog-qa",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "QPS（每秒请求数，按状态）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(qa_requests_total[1m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "延迟 P50 / P95（秒）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(qa_latency_seconds_bucket[5m])))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(qa_latency_seconds_bucket[5m])))",
          "legendFormat": "P95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Token 消耗速率（个/秒）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (kind) (rate(llm_tokens_total[1m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "检索为空占比（RAG 质量哨兵）",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } },
      "targets": [
        {
          "expr": "rate(retrieval_empty_total[5m]) / sum (rate(qa_requests_total[5m]))",
          "legendFormat": "空检索占比"
        }
      ]
    }
  ],
  "schemaVersion": 39
}
