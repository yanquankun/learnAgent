---
config:
  theme: default
  flowchart:
    curve: basis
    nodeSpacing: 40
    rankSpacing: 50
---
flowchart TB
    qalogs[("qa_logs<br/>来自监控流程（第一章）")] -->|"采样 + 人工筛选标注"| evalset["自建评估集<br/>问题 / 期望来源 / 期望行为"]

    subgraph daily ["每次改动都跑：自建回归（秒级 / 零成本 / 结果确定）"]
        run["批量跑评估集"]
        rules["规则指标<br/>hit@K / 拒答正确率"]
        report["markdown 报告<br/>+ CI exit code"]
        run --> rules --> report
    end

    subgraph milestone ["里程碑才跑：Ragas（花钱 / 有波动）"]
        ragas["LLM as Judge<br/>（DeepSeek 当裁判）"]
        scores["四大指标打分<br/>忠实度 / 答案相关性<br/>上下文精确率<br/>上下文召回率"]
        ragas --> scores
    end

    evalset --> run
    evalset -->|"重要版本 / 大改动"| ragas

    report --> gate{"回归红线<br/>通过？"}
    gate -->|"通过"| ship["放心合入 / 上线"]
    gate -->|"不通过"| fix["定位退化原因<br/>调切片 / 检索参数 / Prompt"]
    fix -->|"改完重新回归"| run
    scores -.->|"指出薄弱维度，指导调优"| fix
    ship -.->|"新的真实问答继续落库"| qalogs

    style daily fill:#f0fdf4,stroke:#4ade80
    style milestone fill:#fefce8,stroke:#facc15
    style ship fill:#eff6ff,stroke:#60a5fa
    style fix fill:#fef2f2,stroke:#f87171
