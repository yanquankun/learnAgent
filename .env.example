# =====================================================================
# learnAgent 全局环境变量模板
#
# 使用方法：
#   1. 在仓库根目录执行：cp .env.example .env
#   2. 填写下方的 LLM_API_KEY
#   3. 所有章节的代码都会自动「向上查找」这个 .env 文件，
#      因此 API Key 只需要在这里配置一次，所有章节通用。
#
# 注意：.env 已被 .gitignore 忽略，不会被提交到 git，请放心填写密钥。
# =====================================================================

# ---------------------- LLM 配置（DeepSeek） ----------------------
# DeepSeek 开放平台注册并创建 API Key：https://platform.deepseek.com/api_keys
# 新用户有免费额度，按 token 计费，学习成本极低
LLM_API_KEY=sk-请替换成你自己的key

# DeepSeek 的 OpenAI 兼容接口地址（无需修改）
# 如果以后想换其他 OpenAI 兼容服务（如通义千问、Kimi、OpenAI 官方），
# 只需要改这三个变量，所有章节代码不用动
LLM_BASE_URL=https://api.deepseek.com

# 模型名：
#   deepseek-chat     —— 通用对话模型（本课程默认使用）
#   deepseek-reasoner —— 推理模型（思考更深，速度更慢，费用更高）
LLM_MODEL=deepseek-chat

# ---------------------- Embedding 配置 ----------------------
# 本课程默认使用「本地 FastEmbed 模型」做文本向量化（免费、离线、无需 Key），
# 所以下面这些默认不用配置。
#
# 如果以后想换成 OpenAI 兼容的 Embedding API（如阿里云 DashScope），
# 取消注释并填写即可：
# EMBEDDING_PROVIDER=api
# EMBEDDING_API_KEY=sk-xxxxxxxx
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3

# ---------------------- HuggingFace 镜像 ----------------------
# FastEmbed 第一次运行时需要从 HuggingFace 下载模型文件（约 90MB），
# 国内网络环境建议保留这个镜像地址，加速下载
HF_ENDPOINT=https://hf-mirror.com

# =====================================================================
# 以下配置仅 07-实战 模块使用（学 01~06 模块时无需关心）
# =====================================================================

# ---------------------- 文章数据源（07 模块二章起） ----------------------
# local  = 课程自带的模拟仓库（mock_repo 目录，离线可用，学习时推荐）
# github = 你的真实 GitHub 文章仓库（上线时切换，代码无需任何改动）
BLOG_SOURCE=local

# BLOG_SOURCE=github 时填写：
# GITHUB_REPO=你的用户名/博客文章仓库名
# GITHUB_TOKEN=ghp_xxxx          # 私有仓库需要；公开仓库可留空
# GITHUB_BRANCH=main

# 文章链接规则：article_id 如何拼成你博客的文章 URL
BLOG_URL_TEMPLATE=https://blog.example.com/posts/{id}

# ---------------------- 向量库（07 模块三章起用 Docker 服务端） ----------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=blog_chunks

# 用户长期记忆的 collection（08 模块三章接入，与博客切片分库，默认值即可）
# USER_MEMORY_COLLECTION=user_memories

# ---------------------- Webhook 与管理接口（07 模块五章起） ----------------------
# 生成强随机值：openssl rand -hex 24
WEBHOOK_SECRET=请替换成随机密钥
ADMIN_TOKEN=请替换成随机令牌

# ---------------------- 可观测性（07 模块七章，可选） ----------------------
# OTel 追踪导出：off（默认）/ console（打印到控制台）/ jaeger（发往本地4318端口）
# OTEL_EXPORT=off

# ---------------------- 部署（07 模块八章，容器内使用） ----------------------
# SQLite 数据目录（账本/qa_logs/会话存档）；容器部署时指向挂载卷
# DATA_DIR=/app/data
