          <mxGeometry x="410" y="90" width="1020" height="1010" as="geometry" />
        </mxCell>

        <mxCell id="title" value="03 · Agent ReAct 循环 · 运行时架构" style="text;html=1;align=left;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#333333;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;" vertex="1" parent="1">
