        <mxCell id="s_maintain" value="难点是维护，不是存储：不整合&#10;三个月变「重复+矛盾」垃圾场；&#10;冲突要「更新」不要「追加」" style="rounded=1;whiteSpace=wrap;html=1;sketch=1;curveFitting=1;jiggle=2;hachureGap=4;fillColor=#fcf3cf;strokeColor=#999999;strokeWidth=1.5;fontSize=11;fontColor=#555555;align=left;spacingLeft=6;" vertex="1" parent="1">
